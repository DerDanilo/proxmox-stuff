#!/usr/bin/env bash
# shellcheck disable=SC1090
# =============================================================================
# {{ pmg_domain_mgmt_script }} — Proxmox Mail Gateway domain management
# -----------------------------------------------------------------------------
# Managed by Ansible (role: pmg_domain_mgmt). Local edits will be overwritten.
#
# Talks to the PMG REST API to manage, for a single relay domain:
#   * the relay domain entry itself     (/config/domains)
#   * its transport map entry           (/config/transport)   -- optional (-t)
#   * its DKIM signing entry            (/config/dkim/domains) -- optional (-k)
#
# The script contains NO secrets. Connection details and credentials are read
# from a separate, root-only config file (see CONFIG_FILE below), or from the
# environment when that file is absent. PMG has no API tokens for the config
# API, so authentication uses the classic ticket flow (POST username+password
# to /access/ticket, then send the ticket cookie + CSRF header on writes).
#
# Exit codes: 0 = success / desired state reached, 1 = error.
# =============================================================================

set -uo pipefail

# -----------------------------------------------------------------------------
# Built-in defaults (non-secret). Overridden by the config file / environment.
# -----------------------------------------------------------------------------
CONFIG_FILE="${PMG_CONFIG:-{{ pmg_domain_mgmt_config_file }}}"

PMG_HOST="${PMG_HOST:-}"
PMG_USERNAME="${PMG_USERNAME:-}"
PMG_PASSWORD="${PMG_PASSWORD:-}"
# Verify the PMG TLS certificate (true) or skip verification (false, e.g. for a
# self-signed PMG cert). Kept configurable on purpose — never hard-code "-k".
PMG_TLS_VERIFY="${PMG_TLS_VERIFY:-{{ pmg_domain_mgmt_tls_verify | string | lower }}}"
# Fallback command used when -C/--command is omitted entirely.
PMG_DEFAULT_COMMAND="${PMG_DEFAULT_COMMAND:-{{ pmg_domain_mgmt_default_command | lower }}}"
# Seconds to wait before the post-change verification re-read (lets PMG run
# postmap and settle). Set to 0 to skip the wait.
PMG_SLEEP_LENGTH="${PMG_SLEEP_LENGTH:-{{ pmg_domain_mgmt_sleep_length }}}"
# Transport-map defaults, applied when the matching flag is not given.
PMG_TRANSPORT_PORT="${PMG_TRANSPORT_PORT:-{{ pmg_domain_mgmt_transport_port }}}"
PMG_TRANSPORT_PROTOCOL="${PMG_TRANSPORT_PROTOCOL:-{{ pmg_domain_mgmt_transport_protocol }}}"
PMG_TRANSPORT_USE_MX="${PMG_TRANSPORT_USE_MX:-{{ pmg_domain_mgmt_transport_use_mx | int }}}"

# -----------------------------------------------------------------------------
# Tiny helpers
# -----------------------------------------------------------------------------
DEBUG="false"

log()  { printf '# %s\n' "$*"; }
err()  { printf '# ERROR: %s\n' "$*" >&2; }
die()  { err "$*"; exit 1; }
dbg()  { [[ "$DEBUG" == "true" ]] && printf '# DEBUG: %s\n' "$*" >&2 || true; }

usage() {
    cat <<'EOF'

### Proxmox Mail Gateway Domain Management ###

Usage:
  pmg_domain_mgmt.sh -C get    -d example.com
  pmg_domain_mgmt.sh -C add    -d example.com -c "ACME Corp"
  pmg_domain_mgmt.sh -C add    -d example.com -c "ACME Corp" -t mail.example.com -k
  pmg_domain_mgmt.sh -C update -d example.com -c "ACME Corp" -t mail.example.com -p 25 -k
  pmg_domain_mgmt.sh -C delete -d example.com

Commands (-C):
  get      Report the current state of the domain (read-only).
  add      Ensure the domain (and -t/-k extras) exist; never removes anything.
  update   Ensure the domain exists and update its comment / transport / DKIM.
  delete   Remove the domain AND its transport and DKIM entries (if present).

Options:
  -C, --command     get | add | update | delete
  -d, --domain      Domain to manage, e.g. 'example.com' (required).
  -c, --comment     Comment for the domain / transport / DKIM entry.
                    NOTE: on 'update' an omitted comment clears the existing one.
  -t, --transport   Transport target host (FQDN or IP), e.g. 'mail.example.com'.
                    Presence of this flag enables transport handling.
  -p, --port        Transport port (default: see config, usually 25).
  -P, --protocol    Transport protocol: smtp | lmtp (default: smtp).
  -m, --use-mx      Transport MX lookup: 0 (off) | 1 (on) (default: 0).
  -k, --dkim        Enable DKIM signing for the domain (flag).
  -D, --debug       Verbose output (prints raw API responses to stderr).
  -h, --help        Show this help.

Connection details (host, user, password, TLS verify) come from the config
file or the environment, never from the command line.
EOF
}

# -----------------------------------------------------------------------------
# Configuration loading
# -----------------------------------------------------------------------------
# The config file is plain "VAR='value'" lines. We source it, but values that
# are ALREADY set in the environment take precedence (handy for CI / automation
# secrets): we snapshot them first and restore afterwards.
load_config() {
    local env_host="$PMG_HOST" env_user="$PMG_USERNAME" env_pass="$PMG_PASSWORD"

    if [[ -r "$CONFIG_FILE" ]]; then
        dbg "Loading config file: $CONFIG_FILE"
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    else
        dbg "Config file '$CONFIG_FILE' not found/readable — relying on environment."
    fi

    [[ -n "$env_host" ]] && PMG_HOST="$env_host"
    [[ -n "$env_user" ]] && PMG_USERNAME="$env_user"
    [[ -n "$env_pass" ]] && PMG_PASSWORD="$env_pass"
}

# Note: we build the list as a space-prefixed string rather than a bash array
# on purpose — an array-length test (${#...}) would collide with Jinja's
# comment syntax ({# ... #}) when this file is rendered as a template.
require_tools() {
    local missing=""
    for cmd in curl jq; do
        command -v "$cmd" >/dev/null 2>&1 || missing+=" $cmd"
    done
    [[ -z "$missing" ]] || die "Required command(s) not found:$missing"
}

# -----------------------------------------------------------------------------
# API plumbing
# -----------------------------------------------------------------------------
TICKET=""
CSRF=""

# curl flags shared by every call. --insecure is added only when TLS
# verification is disabled. We never use -f/--fail so we can inspect the body
# and HTTP status ourselves.
curl_base_args() {
    CURL_ARGS=(--silent --show-error --connect-timeout 5 --max-time 30)
    [[ "$PMG_TLS_VERIFY" == "true" ]] || CURL_ARGS+=(--insecure)
}

# api METHOD PATH [data-field ...]
# Performs an authenticated request and prints "<body>\n<http_status>".
# Data fields are passed as KEY=VALUE and URL-encoded safely.
api() {
    local method="$1" path="$2"; shift 2
    local url="$PMG_HOST/api2/json$path"
    local args=("${CURL_ARGS[@]}" -X "$method")
    args+=(-b "PMGAuthCookie=$TICKET")
    args+=(-H "CSRFPreventionToken: $CSRF")
    local field
    for field in "$@"; do
        args+=(--data-urlencode "$field")
    done
    args+=(-w $'\n%{http_code}')
    curl "${args[@]}" "$url"
}

# Splits the "<body>\n<status>" output of api() into globals API_BODY/API_STATUS.
api_split() {
    local raw="$1"
    API_STATUS="${raw##*$'\n'}"
    API_BODY="${raw%$'\n'*}"
    # Single-line responses leave body == status; normalise that.
    [[ "$API_BODY" == "$API_STATUS" ]] && API_BODY=""
}

api_ok() { [[ "$API_STATUS" =~ ^2[0-9][0-9]$ ]]; }

# Obtain a ticket + CSRF token via username/password.
api_login() {
    curl_base_args
    local raw
    raw=$(curl "${CURL_ARGS[@]}" \
        --data-urlencode "username=$PMG_USERNAME" \
        --data-urlencode "password=$PMG_PASSWORD" \
        -w $'\n%{http_code}' \
        "$PMG_HOST/api2/json/access/ticket")
    api_split "$raw"
    # Do NOT debug-print the body: it contains the ticket + CSRF token, which are
    # short-lived credentials. Only the status is safe to log.
    dbg "Login HTTP $API_STATUS"
    api_ok || die "Authentication failed (HTTP $API_STATUS). Check host/credentials."

    TICKET=$(jq -r '.data.ticket // empty' <<<"$API_BODY")
    CSRF=$(jq -r '.data.CSRFPreventionToken // empty' <<<"$API_BODY")
    [[ -n "$TICKET" && -n "$CSRF" ]] || die "Login response missing ticket/CSRF token."
    dbg "Authenticated as $PMG_USERNAME"
}

# entry_exists ENDPOINT DOMAIN -> 0 if a child with .domain == DOMAIN exists.
# Uses exact JSON matching (not substring), so 'example.com' never matches
# 'notexample.com'.
entry_exists() {
    local path="$1" domain="$2" raw
    raw=$(api GET "$path"); api_split "$raw"
    api_ok || { dbg "GET $path -> HTTP $API_STATUS"; return 2; }
    jq -e --arg d "$domain" 'any(.data[]?; .domain == $d)' >/dev/null <<<"$API_BODY"
}

domain_exists()    { entry_exists /config/domains "$1"; }
transport_exists() { entry_exists /config/transport "$1"; }
dkim_exists()      { entry_exists /config/dkim/domains "$1"; }

# Pretty-print a single matching entry (for 'get').
show_entry() {
    local path="$1" domain="$2" raw
    raw=$(api GET "$path"); api_split "$raw"
    api_ok || return 1
    jq -r --arg d "$domain" '.data[]? | select(.domain == $d)' <<<"$API_BODY"
}

# -----------------------------------------------------------------------------
# Domain / transport / DKIM mutations
# -----------------------------------------------------------------------------
mutate() {  # mutate "human label" METHOD PATH [data ...]
    local label="$1" method="$2" path="$3"; shift 3
    local raw; raw=$(api "$method" "$path" "$@"); api_split "$raw"
    if api_ok; then
        log "$label: OK"
    else
        err "$label failed (HTTP $API_STATUS): $API_BODY"
        return 1
    fi
}

add_domain()    { mutate "Add domain"    POST   /config/domains          "domain=$DOMAIN" "comment=$COMMENT"; }
update_domain() { mutate "Update domain" PUT    "/config/domains/$DOMAIN" "comment=$COMMENT"; }
delete_domain() { mutate "Delete domain" DELETE "/config/domains/$DOMAIN"; }

add_transport() {
    mutate "Add transport" POST /config/transport \
        "domain=$DOMAIN" "host=$TRANSPORT" "comment=$COMMENT" \
        "protocol=$PMG_TRANSPORT_PROTOCOL" "port=$PORT" "use_mx=$USE_MX"
}
update_transport() {
    mutate "Update transport" PUT "/config/transport/$DOMAIN" \
        "host=$TRANSPORT" "comment=$COMMENT" \
        "protocol=$PMG_TRANSPORT_PROTOCOL" "port=$PORT" "use_mx=$USE_MX"
}
delete_transport() { mutate "Delete transport" DELETE "/config/transport/$DOMAIN"; }

add_dkim()    { mutate "Add DKIM domain"    POST   /config/dkim/domains          "domain=$DOMAIN" "comment=$COMMENT"; }
update_dkim() { mutate "Update DKIM domain" PUT    "/config/dkim/domains/$DOMAIN" "comment=$COMMENT"; }
delete_dkim() { mutate "Delete DKIM domain" DELETE "/config/dkim/domains/$DOMAIN"; }

# -----------------------------------------------------------------------------
# High-level commands
# -----------------------------------------------------------------------------
cmd_get() {
    if domain_exists "$DOMAIN"; then
        log "Domain '$DOMAIN' found:"
        show_entry /config/domains "$DOMAIN"
    else
        log "Domain '$DOMAIN' NOT found."
    fi
    if transport_exists "$DOMAIN"; then
        log "Transport for '$DOMAIN' found:"
        show_entry /config/transport "$DOMAIN"
    else
        log "Transport for '$DOMAIN' NOT found."
    fi
    if dkim_exists "$DOMAIN"; then
        log "DKIM signing for '$DOMAIN' enabled:"
        show_entry /config/dkim/domains "$DOMAIN"
    else
        log "DKIM signing for '$DOMAIN' disabled."
    fi
}

# Shared 'add' / 'update' worker. $1 = "add" | "update".
cmd_upsert() {
    local mode="$1" rc=0

    if domain_exists "$DOMAIN"; then
        if [[ "$mode" == "update" ]]; then
            log "Domain exists — updating."
            update_domain || rc=1
        else
            log "Domain already exists — leaving as is."
        fi
    else
        log "Domain does not exist — adding."
        add_domain || rc=1
    fi

    if [[ -n "$TRANSPORT" ]]; then
        if transport_exists "$DOMAIN"; then
            if [[ "$mode" == "update" ]]; then
                log "Transport exists — updating."
                update_transport || rc=1
            else
                log "Transport already exists — leaving as is."
            fi
        else
            log "Transport does not exist — adding."
            add_transport || rc=1
        fi
    fi

    if [[ "$DKIM" == "true" ]]; then
        if dkim_exists "$DOMAIN"; then
            if [[ "$mode" == "update" ]]; then
                log "DKIM domain exists — updating."
                update_dkim || rc=1
            else
                log "DKIM domain already exists — leaving as is."
            fi
        else
            log "DKIM domain does not exist — adding."
            add_dkim || rc=1
        fi
    fi

    return "$rc"
}

# Delete the domain plus any transport / DKIM entry, regardless of -t/-k.
cmd_delete() {
    local rc=0
    if domain_exists "$DOMAIN"; then
        delete_domain || rc=1
    else
        log "Domain does not exist — nothing to delete."
    fi
    if transport_exists "$DOMAIN"; then
        delete_transport || rc=1
    else
        log "Transport does not exist — nothing to delete."
    fi
    if dkim_exists "$DOMAIN"; then
        delete_dkim || rc=1
    else
        log "DKIM domain does not exist — nothing to delete."
    fi
    return "$rc"
}

# Re-read state after a change and confirm it matches the intent.
verify() {
    local mode="$1" rc=0

    if [[ "${PMG_SLEEP_LENGTH:-0}" -gt 0 ]]; then
        log "Waiting ${PMG_SLEEP_LENGTH}s before verification..."
        sleep "$PMG_SLEEP_LENGTH"
    fi
    log "Verifying result..."

    case "$mode" in
        add|update)
            domain_exists "$DOMAIN" || { err "Domain missing after $mode."; rc=1; }
            if [[ -n "$TRANSPORT" ]]; then
                transport_exists "$DOMAIN" || { err "Transport missing after $mode."; rc=1; }
            fi
            if [[ "$DKIM" == "true" ]]; then
                dkim_exists "$DOMAIN" || { err "DKIM domain missing after $mode."; rc=1; }
            fi
            ;;
        delete)
            ! domain_exists "$DOMAIN"    || { err "Domain still present after delete."; rc=1; }
            ! transport_exists "$DOMAIN" || { err "Transport still present after delete."; rc=1; }
            ! dkim_exists "$DOMAIN"      || { err "DKIM domain still present after delete."; rc=1; }
            ;;
    esac

    [[ "$rc" -eq 0 ]] && log "Verification OK." || err "Verification FAILED — check manually."
    return "$rc"
}

# -----------------------------------------------------------------------------
# Argument parsing
# -----------------------------------------------------------------------------
COMMAND=""
DOMAIN=""
COMMENT=""
TRANSPORT=""
DKIM="false"
PORT=""
USE_MX=""

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)       usage; exit 0 ;;
        -C|--command)    COMMAND="${2,,}"; shift 2 ;;
        -d|--domain)     DOMAIN="${2,,}"; shift 2 ;;
        -c|--comment)    COMMENT="$2"; shift 2 ;;
        -t|--transport)  TRANSPORT="${2,,}"; shift 2 ;;
        -p|--port)       PORT="$2"; shift 2 ;;
        -P|--protocol)   PMG_TRANSPORT_PROTOCOL="${2,,}"; shift 2 ;;
        -m|--use-mx)     USE_MX="$2"; shift 2 ;;
        -k|--dkim)       DKIM="true"; shift ;;
        -D|--debug)      DEBUG="true"; shift ;;
        --config)        CONFIG_FILE="$2"; shift 2 ;;
        *) err "Invalid argument: '$1'"; usage; exit 1 ;;
    esac
done

# Apply transport defaults for anything not given on the command line.
PORT="${PORT:-$PMG_TRANSPORT_PORT}"
USE_MX="${USE_MX:-$PMG_TRANSPORT_USE_MX}"

# -----------------------------------------------------------------------------
# Validation
# -----------------------------------------------------------------------------
require_tools
load_config

if [[ -z "$COMMAND" ]]; then
    err "No command given — falling back to default '$PMG_DEFAULT_COMMAND'."
    COMMAND="$PMG_DEFAULT_COMMAND"
fi

case "$COMMAND" in
    get|add|update|delete) ;;
    *) die "Invalid command '$COMMAND' (expected get|add|update|delete)." ;;
esac

[[ -n "$DOMAIN" ]]       || die "No domain given (-d/--domain)."
[[ -n "$PMG_HOST" ]]     || die "PMG_HOST is not set (config file or environment)."
[[ -n "$PMG_USERNAME" ]] || die "PMG_USERNAME is not set (config file or environment)."
[[ -n "$PMG_PASSWORD" ]] || die "PMG_PASSWORD is not set (config file or environment)."

# RFC-1035-ish domain sanity check (4..253 chars, valid labels, real TLD).
if ! grep -qP '(?=^.{4,253}$)(^(?:[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?\.)+[a-zA-Z]{2,}$)' <<<"$DOMAIN"; then
    die "Domain name '$DOMAIN' is not valid."
fi

case "$PMG_TRANSPORT_PROTOCOL" in
    smtp|lmtp) ;;
    *) die "Invalid transport protocol '$PMG_TRANSPORT_PROTOCOL' (expected smtp|lmtp)." ;;
esac

cat <<EOF
###########################
PMG host:   $PMG_HOST
TLS verify: $PMG_TLS_VERIFY
Command:    $COMMAND
Domain:     $DOMAIN
Comment:    $COMMENT
Transport:  ${TRANSPORT:-<none>}${TRANSPORT:+ (proto=$PMG_TRANSPORT_PROTOCOL port=$PORT use_mx=$USE_MX)}
DKIM:       $DKIM
###########################
EOF

# -----------------------------------------------------------------------------
# Run
# -----------------------------------------------------------------------------
curl_base_args
# Quick reachability probe before we try to authenticate.
if ! curl "${CURL_ARGS[@]}" --output /dev/null "$PMG_HOST/api2/json/access/ticket"; then
    die "PMG API at $PMG_HOST is not reachable."
fi

api_login

case "$COMMAND" in
    get)
        cmd_get
        exit 0
        ;;
    add|update)
        cmd_upsert "$COMMAND" || exit 1
        verify "$COMMAND" || exit 1
        ;;
    delete)
        cmd_delete || exit 1
        verify delete || exit 1
        ;;
esac

exit 0
