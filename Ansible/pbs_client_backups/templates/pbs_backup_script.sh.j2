#!/bin/bash
{{ ansible_managed | comment }}

{% if (item.pbs_encryption_password is defined and item.pbs_encryption_password|length > 0) %}
# Using Backup Target specific encryption password
export PBS_ENCRYPTION_PASSWORD='{{ item.pbs_encryption_password }}'
{% endif %}
{% if (item.pbs_encryption_password is not defined) and (pbs_client_backups_pbs_encryption_password is defined and pbs_client_backups_pbs_encryption_password|length >0) %}
# Using global encryption password
export PBS_ENCRYPTION_PASSWORD='{{ pbs_client_backups_pbs_encryption_password }}'
{% endif %}

{# --- PBS Server Handling --- #}
{% set server_host = item.pbs_pbs_server | default(pbs_client_backups_pbs_server, true) | mandatory %}
{% set server_port = item.pbs_pbs_server_port | default(pbs_client_backups_pbs_server_port, true) | default('8007', true) %}
{# Eckige Klammern bei IPv4/DNS entfernen #}
{% set cleaned_host = server_host | regex_replace('^\\[|\\]$', '') %}
{# Erkennung #}
{% if cleaned_host | regex_search('^[0-9a-fA-F:]+$') and not cleaned_host | regex_search('\\.') %}
  {# IPv6 -> einklammern #}
  {% set PBS_SERVER = '[' ~ cleaned_host ~ ']:' ~ server_port %}
{% elif cleaned_host | regex_search('^\\d+\\.\\d+\\.\\d+\\.\\d+$') %}
  {# IPv4 -> einfach host:port #}
  {% set PBS_SERVER = cleaned_host ~ ':' ~ server_port %}
{% else %}
  {# DNS oder sonstiges -> ebenfalls host:port #}
  {% set PBS_SERVER = cleaned_host ~ ':' ~ server_port %}
{% endif %}

export PBS_SERVER='{{ PBS_SERVER }}'

export PBS_FINGERPRINT='{{ item.pbs_pbs_fingerprint | d(pbs_client_backups_pbs_fingerprint) }}'
export PBS_PASSWORD='{{ item.pbs_password | default(pbs_client_backups_pbs_password, true) | mandatory }}'
export PBS_USER_STRING='{{ item.pbs_user_string | default(pbs_client_backups_pbs_user_string, true) | mandatory }}'
export PBS_DATASTORE='{{ item.pbs_pbs_datastore | default(pbs_client_backups_pbs_datastore, true) | mandatory }}'
export PBS_REPOSITORY="${PBS_USER_STRING}@${PBS_SERVER}:${PBS_DATASTORE}"

{# Set namespace if specified #}
{% set ns = item.pbs_pbs_namespace | default(pbs_client_Backups_pbs_namespace, true) %}

{# --- Info Summary --- #}
echo "---------------------------------------"
echo " Proxmox Backup Configuration Summary"
echo "---------------------------------------"
echo "BACKUP-ID:      {{ item.name }}"
echo "PBS User:       ${PBS_USER_STRING}"
echo "PBS Server:     ${PBS_SERVER}"
echo "PBS Port:       {{ server_port }}"
echo "PBS Datastore:  ${PBS_DATASTORE}"
{% if ns %}
echo "PBS Namespace:  {{ ns }}"
{% else %}
echo "PBS Namespace:  (none set)"
{% endif %}
echo "---------------------------------------"
echo "Configuration loaded successfully."

if [ $# -le 0 ]; then
    printf "# List backups and exit.\n"
    printf "***************************\n"
    proxmox-backup-client list{% if ns %} --ns "{{ ns }}" {%- endif %}  
    exit 0
fi

if [[ "$*" == *-backup* ]] || [[ "$*" == *-b* ]]; then
printf "Create PBS backup with BACKUP-ID:{{ item.name }} of \n{% for source in item.source %}- {{ source.path }} to {{ source.name }}.pxar\n{% endfor -%}...\n"
printf "***************************\n"
proxmox-backup-client list{% if ns %} --ns "{{ ns }}" {%- endif %}  
printf "***************************\n"
proxmox-backup-client backup {% for source in item.source %} {{ source.name }}.pxar:"{{ source.path }}"{% if (source.includedev is defined and source.includedev|length > 0) %}{% for device_path in source.includedev %} --include-dev "{{ device_path }}"{% endfor %}{% endif %}{% endfor %} --backup-id "{{ item.name }}" --skip-lost-and-found{% if (item.pbs_encryption_keyfile is defined and item.pbs_encryption_keyfile|length > 0) %} --keyfile "{{ pbs_client_backups_keyfile_base }}_{{ item.pbs_encryption_keyfile }}"{% endif %}{% if (item.pbs_encryption_keyfile is not defined) and (pbs_client_backups_pbs_encryption_keyfile is defined and pbs_client_backups_pbs_encryption_keyfile|length > 0) %} --keyfile "{{ pbs_client_backups_keyfile_base }}_{{ pbs_client_backups_pbs_encryption_keyfile }}"{% endif %}{% if ns %} --ns "{{ ns }}" {%- endif %}  

proxmox-backup-client list{% if ns %} --ns "{{ ns }}" {%- endif %}  
printf "***************************\n"
echo "Done."
fi