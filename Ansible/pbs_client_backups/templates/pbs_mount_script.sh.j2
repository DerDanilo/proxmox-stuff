#!/bin/bash
{{ ansible_managed | comment }}
#
# Read-only FUSE mount helper for PBS backup target "{{ item.name }}".
# Managed by the Ansible role "pbs_client_backups" - do not edit by hand.
# NOTE: the PBS connection block below is intentionally identical to
# pbs_backup_script.sh.j2 - update both templates together.
#
# Run with "help" (or -h / --help) for usage.
#
{% set server_host = item.pbs_pbs_server | default(pbs_client_backups_pbs_server, true) | mandatory %}
{% set server_port = item.pbs_pbs_server_port | default(pbs_client_backups_pbs_server_port, true) | default('8007', true) %}
{% set ns = item.pbs_pbs_namespace | default(pbs_client_backups_pbs_namespace, true) %}
{% set enc_pass = item.pbs_encryption_password | default(pbs_client_backups_pbs_encryption_password, true) %}
{% if (item.pbs_encryption_keyfile is defined and item.pbs_encryption_keyfile | length > 0) %}
{%   set keyfile = pbs_client_backups_keyfile_base ~ '_' ~ item.pbs_encryption_keyfile %}
{% elif (pbs_client_backups_pbs_encryption_keyfile is defined and pbs_client_backups_pbs_encryption_keyfile | length > 0) %}
{%   set keyfile = pbs_client_backups_keyfile_base ~ '_' ~ pbs_client_backups_pbs_encryption_keyfile %}
{% else %}
{%   set keyfile = '' %}
{% endif %}
{% set datastore = item.pbs_pbs_datastore | default(pbs_client_backups_pbs_datastore, true) | mandatory %}
{% set cleaned_host = server_host | regex_replace('^\\[|\\]$', '') %}
{% if cleaned_host is search(':') %}
{%   set pbs_server = '[' ~ cleaned_host ~ ']:' ~ server_port %}
{% else %}
{%   set pbs_server = cleaned_host ~ ':' ~ server_port %}
{% endif %}
{% set mountpoint = item.pbs_mount_path | default(pbs_client_backups_mount_base ~ '_' ~ datastore ~ '_' ~ item.name, true) %}
{% if enc_pass %}
# Client-side encryption passphrase (needed to read encrypted archives)
export PBS_ENCRYPTION_PASSWORD={{ enc_pass | quote }}
{% endif %}
export PBS_SERVER={{ pbs_server | quote }}
export PBS_FINGERPRINT={{ item.pbs_pbs_fingerprint | default(pbs_client_backups_pbs_fingerprint, true) | quote }}
export PBS_PASSWORD={{ item.pbs_password | default(pbs_client_backups_pbs_password, true) | mandatory | quote }}
export PBS_USER_STRING={{ item.pbs_user_string | default(pbs_client_backups_pbs_user_string, true) | mandatory | quote }}
export PBS_DATASTORE={{ datastore | quote }}
export PBS_REPOSITORY="${PBS_USER_STRING}@${PBS_SERVER}:${PBS_DATASTORE}"

set -u

MOUNTPOINT={{ mountpoint | quote }}
BACKUP_ID={{ item.name | quote }}
ARCHIVES=({% for s in item.source %} {{ (s.name ~ '.pxar') | quote }}{% endfor %} )
# Number of archives, computed at render time. We intentionally do NOT use the
# bash array-length form here, because that brace-plus-hash sequence would be
# mistaken for a Jinja comment opener while this template is rendered.
ARCHIVE_COUNT={{ item.source | length }}
{% if ns %}
NS_ARGS=(--ns {{ ns | quote }})
{% else %}
NS_ARGS=()
{% endif %}
{% if keyfile %}
KEYFILE_ARGS=(--keyfile {{ keyfile | quote }})
{% else %}
KEYFILE_ARGS=()
{% endif %}

PYPARSER=""
trap 'rm -f "$PYPARSER" 2>/dev/null || true' EXIT

have_python() { command -v python3 >/dev/null 2>&1; }
is_mounted()  { mountpoint -q -- "$MOUNTPOINT"; }

# Write the snapshot-list parser to a temp file (reads JSON on stdin, args:
# <menu|pick> <backup-id> [index]). Kept tiny and dependency-free.
write_parser() {
    PYPARSER="$(mktemp)" || return 1
    cat >"$PYPARSER" <<'PYEOF'
import sys, json, datetime
mode = sys.argv[1]
bid = sys.argv[2]
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(3)
snaps = [s for s in data if s.get("backup-id") == bid]
snaps.sort(key=lambda s: s.get("backup-time", 0), reverse=True)
def rfc(t):
    return datetime.datetime.fromtimestamp(int(t), datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
def sid(s):
    return "%s/%s/%s" % (s.get("backup-type", "host"), s.get("backup-id"), rfc(s.get("backup-time")))
def archives(s):
    out = []
    for f in s.get("files", []):
        name = f.get("filename") if isinstance(f, dict) else f
        if not name:
            continue
        if name.endswith(".didx") or name.endswith(".fidx"):
            name = name.rsplit(".", 1)[0]
        out.append(name)
    return ",".join(sorted(set(out)))
if mode == "menu":
    if not snaps:
        sys.stderr.write("  (no snapshots found for backup-id '%s')\n" % bid)
        sys.exit(0)
    for i, s in enumerate(snaps, 1):
        sys.stderr.write("  %2d) %s   [%s]\n" % (i, sid(s), archives(s)))
elif mode == "pick":
    idx = int(sys.argv[3])
    if idx < 1 or idx > len(snaps):
        sys.exit(1)
    sys.stdout.write(sid(snaps[idx - 1]))
PYEOF
}

snapshots_json() {
    proxmox-backup-client snapshot list --output-format json "${NS_ARGS[@]}" 2>/dev/null
}

# Sets ARCHIVE. Uses $1 if given, else the only archive, else prompts.
pick_archive() {
    if [ -n "${1:-}" ]; then ARCHIVE="$1"; return 0; fi
    if [ "$ARCHIVE_COUNT" -eq 1 ]; then ARCHIVE="${ARCHIVES[0]}"; return 0; fi
    echo "Available archives:" >&2
    local i=1 a
    for a in "${ARCHIVES[@]}"; do echo "  $i) $a" >&2; i=$((i + 1)); done
    if [ ! -t 0 ]; then echo "Non-interactive: pass the archive name as 2nd argument." >&2; return 1; fi
    local sel; read -rp "Select archive number: " sel
    if printf '%s' "$sel" | grep -qE '^[0-9]+$' && [ "$sel" -ge 1 ] && [ "$sel" -le "$ARCHIVE_COUNT" ]; then
        ARCHIVE="${ARCHIVES[$((sel - 1))]}"
    else
        ARCHIVE="$sel"
    fi
    [ -n "${ARCHIVE:-}" ]
}

# Sets SNAPSHOT from $1:
#   - a full snapshot id (contains '/')  -> used as-is
#   - a bare number                      -> the Nth entry from the list (newest = 1)
#   - empty                              -> interactive numbered picker
pick_snapshot() {
    local arg="${1:-}"
    # Full snapshot id: use directly, no need to query the list.
    if [ -n "$arg" ] && printf '%s' "$arg" | grep -q '/'; then
        SNAPSHOT="$arg"; return 0
    fi

    local json
    json="$(snapshots_json)" || { echo "ERROR: could not list snapshots from PBS." >&2; return 1; }

    # A number selects directly from the list without prompting.
    if [ -n "$arg" ]; then
        if ! printf '%s' "$arg" | grep -qE '^[0-9]+$'; then
            SNAPSHOT="$arg"; return 0   # neither number nor id: pass through, let PBS validate
        fi
        if ! have_python; then
            echo "Selecting by number needs python3 - pass the full snapshot id instead." >&2; return 1
        fi
        write_parser || return 1
        SNAPSHOT="$(printf '%s' "$json" | python3 "$PYPARSER" pick "$BACKUP_ID" "$arg")" || true
        [ -n "${SNAPSHOT:-}" ] || { echo "No snapshot #$arg for backup-id '$BACKUP_ID' (run 'list')." >&2; return 1; }
        return 0
    fi

    # No argument: show the numbered list and prompt.
    echo "Available snapshots for backup-id '$BACKUP_ID':" >&2
    if have_python; then
        write_parser || return 1
        printf '%s' "$json" | python3 "$PYPARSER" menu "$BACKUP_ID"
    else
        proxmox-backup-client snapshot list "${NS_ARGS[@]}" >&2 || true
    fi
    if [ ! -t 0 ]; then echo "Non-interactive: pass a snapshot number or full id as 1st argument." >&2; return 1; fi
    local sel; read -rp "Select a number (or full snapshot id): " sel
    if have_python && printf '%s' "$sel" | grep -qE '^[0-9]+$'; then
        SNAPSHOT="$(printf '%s' "$json" | python3 "$PYPARSER" pick "$BACKUP_ID" "$sel")" || true
    else
        SNAPSHOT="$sel"
    fi
    [ -n "${SNAPSHOT:-}" ] || { echo "No snapshot selected." >&2; return 1; }
}

do_status() {
    echo "Backup-ID:   $BACKUP_ID"
    echo "Mount point: $MOUNTPOINT"
    echo "Archives:    ${ARCHIVES[*]}"
    if is_mounted; then
        echo "State:       MOUNTED (read-only)"
        grep -F " $MOUNTPOINT " /proc/mounts 2>/dev/null || true
    else
        echo "State:       not mounted"
    fi
}

do_list() {
    echo "Available snapshots for backup-id '$BACKUP_ID':"
    if have_python; then
        write_parser || return 1
        snapshots_json | python3 "$PYPARSER" menu "$BACKUP_ID"
    else
        proxmox-backup-client snapshot list "${NS_ARGS[@]}"
    fi
}

do_mount() {
    local snap_arg="${1:-}" arch_arg="${2:-}"
    if is_mounted; then
        echo "Already mounted at $MOUNTPOINT (use 'remount' or 'umount')." >&2
        return 1
    fi
    pick_archive "$arch_arg" || return 1
    pick_snapshot "$snap_arg" || return 1
    mkdir -p -- "$MOUNTPOINT"
    echo "Mounting $SNAPSHOT ($ARCHIVE) read-only at $MOUNTPOINT ..."
    proxmox-backup-client mount "$SNAPSHOT" "$ARCHIVE" "$MOUNTPOINT" "${NS_ARGS[@]}" "${KEYFILE_ARGS[@]}"
    local rc=$?
    if [ "$rc" -eq 0 ]; then
        echo "Mounted read-only. Unmount with: $0 umount"
    else
        echo "Mount failed (exit ${rc})." >&2
    fi
    return "$rc"
}

do_umount() {
    if ! is_mounted; then echo "Not mounted: $MOUNTPOINT"; return 0; fi
    echo "Unmounting $MOUNTPOINT ..."
    if umount -- "$MOUNTPOINT"; then
        rmdir -- "$MOUNTPOINT" 2>/dev/null || true
        echo "Unmounted."
    else
        echo "umount failed for $MOUNTPOINT." >&2
        return 1
    fi
}

usage() {
    local me; me="$(basename -- "$0")"
    echo "Read-only mount helper for PBS backup \"$BACKUP_ID\"."
    echo "Mount point: $MOUNTPOINT"
    echo
    echo "Usage: $me [COMMAND] [ARGS]"
    echo
    echo "Commands:"
    printf '  %-9s %s\n' "status"  "Show the mount point and whether it is mounted (default)."
    printf '  %-9s %s\n' "list"    "List available snapshots, newest first."
    printf '  %-9s %s\n' "mount"   "Mount a snapshot read-only:  mount [SNAPSHOT] [ARCHIVE]"
    printf '  %-9s %s\n' ""        "SNAPSHOT may be a number from 'list' or a full id."
    printf '  %-9s %s\n' ""        "Omit it for an interactive picker. The mount point"
    printf '  %-9s %s\n' ""        "is created automatically."
    printf '  %-9s %s\n' "remount" "Unmount (if mounted), then mount again (same args)."
    printf '  %-9s %s\n' "umount"  "Unmount and remove the empty mount point. (alias: unmount)"
    printf '  %-9s %s\n' "help"    "Show this help. (aliases: -h, --help)"
    echo
    echo "Examples:"
    printf '  %s\n' "$me list"
    printf '  %s\n' "$me mount            # interactive picker"
    printf '  %s\n' "$me mount 1          # newest snapshot from the list"
    printf '  %s\n' "$me mount host/$BACKUP_ID/2026-06-11T18:41:03Z"
    printf '  %s\n' "$me umount"
}

cmd="${1:-status}"
case "$cmd" in
    status)             do_status ;;
    list)               do_list ;;
    mount)              do_mount "${2:-}" "${3:-}" ;;
    remount)            do_umount; do_mount "${2:-}" "${3:-}" ;;
    umount|unmount)     do_umount ;;
    help|-h|--help)     usage ;;
    *)                  usage >&2; exit 2 ;;
esac
